class Solution {
    public boolean validMountainArray(int[] arr) {
        if(arr.length>=3){
            int idx =-1;
            for(int i =0 ; i<arr.length-1 ; i++){
                if(arr[i]>arr[i+1]){
                    idx=i;
                    break;
                }
            }
            if(idx == -1 || idx == 0) return false;
            for(int i =0 ; i<idx ;i++){
                if(arr[i]>=arr[i+1]) return false;
            }
            for(int i =idx ;i<arr.length-1 ; i++){
                if(arr[i]<=arr[i+1]) return false;
            }
            
        return true;
        }
        return false;
    }
}
