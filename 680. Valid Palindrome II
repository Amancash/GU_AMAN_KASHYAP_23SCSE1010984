class Solution {
    public boolean validPalindrome(String s) {
        int i =0;
        int j = s.length()-1;
        int count=0;
        while(i<j){
            if(s.charAt(i)!=s.charAt(j)){
            
                return helper(i+1,j,s) || helper(i,j-1,s);
            }
            else{
                i++;
            j--;
            }
            
        }
        return true;
    }
    public boolean helper(int i , int j,String s){
        while(i<j){
            if(s.charAt(i) != s.charAt(j)){
                return false;
            }
            i++;
            j--;
            
        }
        return true;
    }
}
