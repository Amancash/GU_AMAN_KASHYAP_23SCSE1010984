class Solution {
    public int maxScore(int[] arr, int k) {
        int lsum=0;
        int rsum=0;
        int sum =0;
        for(int i =0 ; i<k ; i++){
            lsum+=arr[i];
            sum=lsum;
        }
        int ridx=arr.length-1;
        for(int i=k-1 ; i>=0;i--){
            lsum=lsum-arr[i];
            rsum= rsum+arr[ridx--];
            sum = Math.max(sum,lsum+rsum);
        }
        return sum;
    }
}
